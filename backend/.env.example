DATABASE_URL=postgres://postgres:postgres@localhost:5432/movie_matcher?sslmode=disable
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=8080
RECOMMENDATION_SERVICE_URL=http://localhost:8000
# Очередь запросов к recommendation service (макс. параллельных запросов, размер очереди)
RECOMMENDATION_QUEUE_CONCURRENT=5
RECOMMENDATION_QUEUE_SIZE=100

# Восстановление пароля по email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@movie-matcher.local
# URL страницы сброса пароля на фронте (к ссылке добавится ?token=...)
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password

# Начальный владелец: при первом запуске создаётся пользователь с ролью owner, если пользователя с таким email нет
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me-secure-password
OWNER_NAME=Owner
OWNER_USERNAME=owner

# Загрузка файлов на сервер (постеры, аватарки, трейлеры). Путь на диске.
UPLOAD_DIR=./uploads
# Макс. размер: изображения (байты), видео (байты)
MAX_UPLOAD_SIZE_IMAGE=10485760
MAX_UPLOAD_SIZE_VIDEO=1073741824

# Ключ шифрования сообщений (32 байта в hex = 64 символа). Если не задан, используется JWT_SECRET.
# Генерация: openssl rand -hex 32
# MESSAGE_ENCRYPTION_KEY=

# Web Push (VAPID): для браузерных push-уведомлений. Если не заданы — push не отправляются.
# Генерация ключей: например через https://vapidkeys.com/ или библиотеку web-push (npm).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
