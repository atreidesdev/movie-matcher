# =============================================================================
# Movie Matcher — переменные окружения для всего проекта
# Скопируйте в .env и при необходимости отредактируйте.
# При запуске через run.ps1 / run.sh корневой .env копируется в backend/,
# recommendation-service/ и frontend/.
# =============================================================================

# -----------------------------------------------------------------------------
# База данных (PostgreSQL)
# Используется backend, recommendation-service и docker-compose
# -----------------------------------------------------------------------------
# Формат postgresql:// подходит и для Go (backend), и для Python (recommendation-service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/movie_matcher?sslmode=disable

# -----------------------------------------------------------------------------
# Backend (Go)
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=8080
RECOMMENDATION_SERVICE_URL=http://localhost:8000
RECOMMENDATION_QUEUE_CONCURRENT=5
RECOMMENDATION_QUEUE_SIZE=100

# SMTP (восстановление пароля)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@movie-matcher.local
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password

# Начальный владелец (создаётся при первом запуске)
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me-secure-password
OWNER_NAME=Owner
OWNER_USERNAME=owner

# Загрузка файлов (постеры, аватарки, трейлеры)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_IMAGE=10485760
MAX_UPLOAD_SIZE_VIDEO=1073741824

# Web Push (VAPID): для браузерных push-уведомлений. Если не заданы — push не отправляются.
# Как получить пару ключей: npx web-push generate-vapid-keys  или https://vapidkeys.com/
# Публичный ключ также пропишите во Frontend как VITE_VAPID_PUBLIC_KEY.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Recommendation Service (Python)
# Backend подставляет DATABASE_URL сам; здесь дублируем для удобства
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIM=384
USE_FAISS=true
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# Frontend (Vite)
# Базовый URL API (без /api/v1 в конце — подставится автоматически)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8080/api/v1

# Публичный VAPID для Web Push (скопируйте сюда значение VAPID_PUBLIC_KEY из бэкенда).
# VITE_VAPID_PUBLIC_KEY=

# Мок API для разработки без бэкенда (ответы из src/mock/mockData.ts)
# VITE_USE_MOCK=true
