{
  "name": "movie-matcher",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "dev:tunnel": "npx --yes localtunnel --port 5173",
    "build": "tsc && vite build",
    "build:mock": "vite build --mode mock",
    "build:pages": "vite build --mode pages",
    "deploy": "npm run build:pages && gh-pages -d dist",
    "lint": "biome lint ./src",
    "lint:eslint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "preview": "vite preview",
    "i18n:validate": "node ./scripts/i18n-validate.mjs",
    "i18n:validate:strict": "node ./scripts/i18n-validate.mjs --fail-on-unused",
    "i18n:report": "node ./scripts/i18n-validate.mjs"
  },
  "dependencies": {
    "@ctrl/tinycolor": "^4.2.0",
    "@react-spring/web": "^10.0.3",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "axios": "^1.6.5",
    "clsx": "^2.1.0",
    "d3-force-3d": "^3.0.6",
    "dompurify": "^3.3.3",
    "easing-coordinates": "^2.0.2",
    "fast-average-color": "^9.5.0",
    "framer-motion": "^12.36.0",
    "gh-pages": "^6.3.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1",
    "react-i18next": "^16.5.4",
    "react-photo-album": "^3.5.1",
    "react-router-dom": "^7.10.0",
    "twemoji": "^14.0.2",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.33",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-precaching": "^7.4.0",
    "workbox-window": "^7.4.0"
  }
}
